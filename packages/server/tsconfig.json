{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*",
        "../../src/*"
      ]
    },
    "allowJs": true,
    "incremental": true
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "index.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
