{
  "name": "@git-for-music/db",
  "version": "1.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "prisma generate",
    "db:push": "set -a; . ../../.env; set +a; prisma db push",
    "migrate": "set -a; . ../../.env; set +a; prisma migrate dev",
    "migrate:deploy": "if [ -z \"$DATABASE_URL\" ] && [ -f ../../.env ]; then set -a; . ../../.env; set +a; fi; prisma migrate deploy",
    "studio": "set -a; . ../../.env; set +a; prisma studio",
    "lint": "pnpm --dir ../.. exec eslint --config eslint.config.mjs packages/db/src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@git-for-music/shared": "workspace:*",
    "@prisma/client": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prisma": "^6.0.0",
    "typescript": "^5.0.0"
  }
}
