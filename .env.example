DATABASE_URL=postgresql://postgres:postgres@localhost:5432/git_for_music
REDIS_URL=redis://localhost:6379

# Local/dev object storage. Set either the OBJECT_STORAGE_* names or the R2_* aliases.
OBJECT_STORAGE_BUCKET_NAME=git-for-music
OBJECT_STORAGE_ACCESS_KEY_ID=minioadmin
OBJECT_STORAGE_SECRET_ACCESS_KEY=minioadmin
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_PUBLIC_URL=http://localhost:9000
OBJECT_STORAGE_INTERNAL_URL=http://localhost:9000

# Optional local/dev secrets used by the Docker Compose stack and upload flow.
DAW_ASSET_UPLOAD_TOKEN_SECRET=dev-only-daw-asset-token-secret
DAW_PLUGIN_UPLOAD_TOKEN_SECRET=dev-only-daw-plugin-token-secret
DAW_WORKER_CALLBACK_SECRET=dev-only-daw-worker-callback-secret
NEXTAUTH_SECRET=dev-only-nextauth-secret

# App and feature defaults.
NEXT_PUBLIC_APP_URL=http://localhost:3000
FEATURE_PLUGINS=true
DAW_ENABLE_ORDINARY_EDIT_HEAD_ADVANCE=false
