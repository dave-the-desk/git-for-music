{
  "$schema": "https://json-schema.org/draft-07/schema",
  "compilerOptions": {
    "strict": true,
    "lib": ["es2022"],
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  }
}
